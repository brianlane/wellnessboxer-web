# Brand
COMPANY_NAME="Wellness Boxer"
SITE_NAME="Wellness Boxer"

# Site URL (used for Stripe success / cancel redirects in local dev)
# In production Vercel sets VERCEL_PROJECT_PRODUCTION_URL automatically.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe (https://dashboard.stripe.com/apikeys)
# Server-side secret key (sk_test_... in test mode, sk_live_... in live).
STRIPE_SECRET_KEY=""
# Webhook signing secret for /api/stripe/webhook (whsec_...).
# Created when you register the webhook endpoint in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (one per SKU in the static catalog).
# Create three Products in Stripe with the listed handles, then paste the
# resulting price_... IDs below. See docs/STRIPE_SETUP.md.
STRIPE_PRICE_SINGLE=""
STRIPE_PRICE_3PACK=""
STRIPE_PRICE_SUBSCRIBE=""
